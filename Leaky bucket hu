#include<stdio.h>
#include<stdlib.h>
#include<time.h>
#include<unistd.h>

#define packetCount 10

int main()
{
    int packets[packetCount];
    int i, bucketSize, outputRate;
    int stored = 0;

    srand(time(0));

    // generate random packet sizes
    for(i = 0; i < packetCount; i++)
        packets[i] = (rand()%6 + 1) * 10;

    printf("Enter Bucket Size: ");
    scanf("%d", &bucketSize);

    printf("Enter Output Rate: ");
    scanf("%d", &outputRate);

    for(i = 0; i < packetCount; i++)
    {
        printf("\nIncoming Packet Size : %d\n", packets[i]);

        // check overflow
        if((stored + packets[i]) <= bucketSize)
        {
            stored += packets[i];

            printf("Packet Accepted\n");
            printf("Bytes in Bucket : %d\n", stored);
        }
        else
        {
            printf("Bucket Overflow! Packet Rejected\n");
        }

        sleep(1);

        // transmit data
        if(stored > 0)
        {
            if(stored <= outputRate)
            {
                printf("%d Bytes Transmitted\n", stored);
                stored = 0;
            }
            else
            {
                printf("%d Bytes Transmitted\n", outputRate);
                stored -= outputRate;
            }
        }

        printf("Bytes Remaining in Bucket : %d\n", stored);
    }

    return 0;
}
